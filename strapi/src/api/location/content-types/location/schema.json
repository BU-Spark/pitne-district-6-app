{
  "kind": "collectionType",
  "collectionName": "locations",
  "info": {
    "singularName": "location",
    "pluralName": "locations",
    "displayName": "Location",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string"
    },
    "place_type": {
      "type": "enumeration",
      "enum": [
        "BCYF Centers",
        "Boston Public Libraries",
        "Parks and Green Space"
      ]
    },
    "description": {
      "type": "text"
    },
    "lat": {
      "type": "float"
    },
    "lng": {
      "type": "float"
    },
    "geohash": {
      "type": "string"
    },
    "phone": {
      "type": "biginteger"
    },
    "website": {
      "type": "string"
    },
    "hours_of_operation": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean"
    },
    "resources": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::resource.resource",
      "mappedBy": "locations"
    },
    "events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event",
      "mappedBy": "locations"
    },
    "address": {
      "type": "customField",
      "options": {
        "info": true
      },
      "customField": "plugin::geodata.geojson"
    }
  }
}
