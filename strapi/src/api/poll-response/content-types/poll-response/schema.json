{
  "kind": "collectionType",
  "collectionName": "poll_responses",
  "info": {
    "singularName": "poll-response",
    "pluralName": "poll-responses",
    "displayName": "Poll Response",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "email": {
      "type": "email"
    },
    "selected_choice": {
      "type": "string",
      "required": true
    },
    "submitted_at": {
      "type": "datetime"
    },
    "poll": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::poll.poll",
      "inversedBy": "poll_responses"
    },
    "Address": {
      "type": "text"
    },
    "Region": {
      "type": "enumeration",
      "enum": [
        "Jamaica Plain",
        "West Roxbury"
      ]
    }
  }
}
