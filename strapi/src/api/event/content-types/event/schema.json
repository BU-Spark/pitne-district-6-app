{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "images": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": true
    },
    "event_type": {
      "type": "enumeration",
      "enum": [
        "voting",
        "community",
        "concert",
        "sports"
      ]
    },
    "start_datetime": {
      "type": "datetime"
    },
    "end_datetime": {
      "type": "datetime"
    },
    "location": {
      "type": "string"
    },
    "link": {
      "type": "string"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "is_active": {
      "type": "boolean"
    }
  }
}
